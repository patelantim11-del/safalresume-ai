# Database
MONGODB_URI=mongodb+srv://USER:PASSWORD@HOST/DATABASE?retryWrites=true&w=majority

# App URLs
NEXTAUTH_URL=https://your-production-domain.vercel.app
NEXT_PUBLIC_BASE_URL=https://your-production-domain.vercel.app
NEXT_PUBLIC_APP_URL=https://your-production-domain.vercel.app

# Authentication
JWT_SECRET=replace_with_a_strong_random_secret
NEXTAUTH_SECRET=replace_with_a_different_strong_random_secret
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_app_password_or_smtp_password
SMTP_SECURE=true
EMAIL_FROM_NAME=SafalResume AI

# AI service: set AI_PROVIDER to gemini or openai, then provide that key.
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key

# Payments
RAZORPAY_KEY_ID=rzp_live_or_test_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Local development only
DEV_RESET_FALLBACK=false
